                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json._id) {",
                  "    pm.collectionVariables.set('meetingId', json._id);",
                  "    console.log('Saved meetingId: ' + json._id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Q2 planning sync\",\n  \"platform\": \"zoom\",\n  \"link\": \"https://zoom.us/j/1234567890\",\n  \"meetingId\": \"123 456 7890\",\n  \"passcode\": \"deeks\",\n  \"scheduledAt\": \"2026-05-15T14:00:00.000Z\",\n  \"notes\": \"Agenda: roadmap review\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/meetings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "meetings"]
